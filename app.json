{
  "expo": {
    "name": "打电话",
    "slug": "BigFontPhone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2E7D32"
      },
      "package": "com.bigfontphone.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "允许访问相册以设置联系人照片",
          "cameraPermission": "允许使用相机拍摄联系人照片"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "7c036461-073e-4891-9ea9-74cef8acd5bd"
      }
    }
  }
}
